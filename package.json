{
  "name": "@sproutpad/conformance",
  "version": "0.1.1",
  "description": "Independent wire, discovery, and governed-loop checker for governed agent-spend APIs",
  "type": "module",
  "license": "MIT AND CC-BY-4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SproutPad/conformance.git"
  },
  "homepage": "https://github.com/SproutPad/conformance#readme",
  "bugs": {
    "url": "https://github.com/SproutPad/conformance/issues"
  },
  "bin": {
    "sproutpad-conformance": "./bin/sproutpad-conformance.mjs"
  },
  "exports": {
    ".": "./lib/suite.mjs",
    "./wire": "./lib/conformance.mjs",
    "./public-evals": "./lib/public-evals.mjs",
    "./canonical": "./lib/canonical.mjs",
    "./verify": "./lib/verify.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "spec/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run --config vitest.config.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
